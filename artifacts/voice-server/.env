PORT=5002
ANNOUNCED_IP=127.0.0.1
# Set this to your public IP or domain when deploying behind a tunnel/load balancer
# ANNOUNCED_IP=your.public.ip.here

# RTC Port range for WebRTC UDP media
RTC_MIN_PORT=40000
RTC_MAX_PORT=49999

# Internal secret used by api-server to authenticate calls to voice-server
INTERNAL_SECRET=bobacord_internal_secret_dev_only
